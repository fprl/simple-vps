#!/usr/bin/env bash
set -euo pipefail

state_dir=/run/simple-vps-fresh-host
mkdir -p "$state_dir"
printf 'curl %s\n' "$*" >> "$state_dir/curl.log"

output=""
url=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    -o)
      output="${2:-}"
      shift 2
      ;;
    -*)
      shift
      ;;
    *)
      url="$1"
      shift
      ;;
  esac
done

if [[ -n "$output" ]]; then
  mkdir -p "$(dirname "$output")"
  printf 'fake curl content for %s\n' "$url" > "$output"
  exit 0
fi

printf 'fake curl content for %s\n' "$url"

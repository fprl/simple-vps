#!/usr/bin/env bash
# Minimal systemctl stub for the container-deploy smoke. The new
# lifecycle only invokes `systemctl reload caddy`; everything else is
# either fake-podman (container ops), fake-caddy (config validate), or
# direct shell. Accept the verbs the deploy path might call and exit
# 0 — no real service supervision needed.
set -euo pipefail

case "${1:-}" in
  daemon-reload|enable|disable|reload|start|stop|restart|is-active|status)
    exit 0
    ;;
  *)
    echo "fake systemctl: unsupported command $*" >&2
    exit 1
    ;;
esac

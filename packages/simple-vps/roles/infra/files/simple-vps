    route_static.set_defaults(func=cmd_route_static)

    route_redirect = route_subparsers.add_parser("redirect", help="Redirect a host to another URL")
    route_redirect.add_argument("host")
    route_redirect.add_argument("--to", required=True)
    route_redirect.add_argument("--app")
    route_redirect.add_argument("--force", action="store_true")
    route_redirect.set_defaults(func=cmd_route_redirect)

    route_remove = route_subparsers.add_parser("remove", help="Remove routes by host or app")
    route_remove.add_argument("host", nargs="?")
    route_remove.add_argument("--app")
    route_remove.add_argument("--force", action="store_true")
    route_remove.set_defaults(func=cmd_route_remove)

    cloudflare = subparsers.add_parser("cloudflare", help="Manage Cloudflare integration")
    cloudflare_subparsers = cloudflare.add_subparsers(dest="cloudflare_command", required=True)

    cloudflare_setup = cloudflare_subparsers.add_parser("setup-tunnel", help="Create or reuse the server tunnel")
    cloudflare_setup.add_argument("--token-file", default=str(CLOUDFLARE_API_TOKEN_PATH))
    cloudflare_setup.add_argument("--account-id")
    cloudflare_setup.add_argument("--name", required=True)
    cloudflare_setup.set_defaults(func=cmd_cloudflare_setup_tunnel)

    cloudflare_publish = cloudflare_subparsers.add_parser("publish", help="Publish a hostname through Cloudflare")
    cloudflare_publish.add_argument("host")
    cloudflare_publish.add_argument("--app", required=True)
    cloudflare_publish.set_defaults(func=cmd_cloudflare_publish)

    cloudflare_remove = cloudflare_subparsers.add_parser("remove", help="Remove Cloudflare hostnames")
    cloudflare_remove.add_argument("host", nargs="?")
    cloudflare_remove.add_argument("--app")
    cloudflare_remove.set_defaults(func=cmd_cloudflare_remove)

    publish = subparsers.add_parser("publish", help="Publish a host to a local app port")
    publish.add_argument("--host", required=True)
    publish.add_argument("--port", required=True)
    publish.add_argument("--force", action="store_true")
    publish.set_defaults(func=cmd_publish)

    unpublish = subparsers.add_parser("unpublish", help="Remove a published host")
    unpublish.add_argument("--host", required=True)
    unpublish.add_argument("--force", action="store_true")
    unpublish.set_defaults(func=cmd_unpublish)

    generate = subparsers.add_parser(
        "generate-caddy",
        help="Regenerate /etc/caddy/Caddyfile from state",
    )
    generate.add_argument("--force", action="store_true")
    generate.set_defaults(func=cmd_generate_caddy)

    app = subparsers.add_parser("app", help="Manage Simple VPS apps")
    app_subparsers = app.add_subparsers(dest="app_command", required=True)

    app_create = app_subparsers.add_parser("create", help="Create an app user and directory layout")
    app_create.add_argument("name")

STATE_VERSION = 2
GENERATED_MARKER = "# Generated by Simple VPS. Do not edit by hand."
HASH_PREFIX = "# simple-vps-sha256: "

HOST_RE = re.compile(
    r"^(?=.{1,253}$)(?!-)[a-z0-9-]{1,63}(?<!-)"
    r"(?:\.(?!-)[a-z0-9-]{1,63}(?<!-))*$"
)
APP_RE = re.compile(r"^[a-z][a-z0-9-]{1,40}$")
SERVICE_RE = re.compile(r"^[a-z][a-z0-9-]{0,30}$")
HEADER_NAME_RE = re.compile(r"^[A-Za-z0-9!#$%&'*+.^_`|~-]+$")
SERVICE_ACTIONS = {"start", "stop", "restart", "status", "is-active", "enable", "disable"}
SYSTEM_USER_RE = re.compile(r"^[a-z_][a-z0-9_-]{0,31}\$?$")
ENV_KEY_RE = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")
BROAD_SUDO_RE = re.compile(r"^([a-z_][a-z0-9_-]{0,31}\$?)\s+ALL=\((?:ALL|ALL:ALL)\)\s+NOPASSWD:\s*ALL$")
HELPER_SUDO_RE = re.compile(
    r"^([a-z_][a-z0-9_-]{0,31}\$?)\s+ALL=\(root\)\s+NOPASSWD:\s*" + re.escape(HELPER_PATH) + r"$"
)


def die(message, code=1):
    print(f"Error: {message}", file=sys.stderr)
    raise SystemExit(code)


def require_root():
    if hasattr(os, "geteuid") and os.geteuid() != 0:
        die("this command must run as root")


def load_state():
    if not STATE_PATH.exists():
        return {"version": STATE_VERSION, "routes": []}

    try:
        state = json.loads(STATE_PATH.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        die(f"invalid state file {STATE_PATH}: {exc}")

    if not isinstance(state, dict):
        die(f"invalid state file {STATE_PATH}: expected object")

    routes = state.get("routes", [])
    if not isinstance(routes, list):
        die(f"invalid state file {STATE_PATH}: routes must be a list")

    version = int(state.get("version", 1))
    if version > STATE_VERSION:
        die(f"unsupported state version {version}; this simple-vps supports up to {STATE_VERSION}")

    normalized = []
    for route in routes:
        if not isinstance(route, dict):
            die(f"invalid state file {STATE_PATH}: route entries must be objects")
        normalized.append(normalize_route(route))

    return {"version": STATE_VERSION, "routes": sort_routes(normalized)}


def write_state(state):
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    atomic_write(STATE_PATH, json.dumps(state, indent=2, sort_keys=True) + "\n", 0o644)


def load_cloudflare_state():
    if not CLOUDFLARE_STATE_PATH.exists():
        return {"version": 1, "routes": {}}
    try:
        state = json.loads(CLOUDFLARE_STATE_PATH.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        die(f"invalid Cloudflare state file {CLOUDFLARE_STATE_PATH}: {exc}")
    if not isinstance(state, dict):
        die(f"invalid Cloudflare state file {CLOUDFLARE_STATE_PATH}: expected object")
    routes = state.get("routes", {})
    if not isinstance(routes, dict):
        die(f"invalid Cloudflare state file {CLOUDFLARE_STATE_PATH}: routes must be an object")
    state["routes"] = routes
    state["version"] = 1
    return state


def write_cloudflare_state(state):
    atomic_write(CLOUDFLARE_STATE_PATH, json.dumps(state, indent=2, sort_keys=True) + "\n", 0o600)


def read_cloudflare_api_token(path=None):
    if path is None:
        path = CLOUDFLARE_API_TOKEN_PATH
    if not path.exists():
        return None
    token = path.read_text(encoding="utf-8").strip()
    return token or None


def atomic_write(path, content, mode):
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=str(path.parent))
    tmp_path = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        os.chmod(tmp_path, mode)
        os.replace(tmp_path, path)
    finally:
        if tmp_path.exists():
            tmp_path.unlink()


def backup_file(path):
    if not path.exists():
        return None

    BACKUP_DIR.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    backup_path = BACKUP_DIR / f"{path.name}.{stamp}"
    shutil.copy2(path, backup_path)
    return backup_path


def cloudflare_api_request(token, method, path, payload=None, query=None):
    url = "https://api.cloudflare.com/client/v4" + path
    if query:
        url += "?" + urllib.parse.urlencode(query)
    data = None
    headers = {"Authorization": f"Bearer {token}", "Accept": "application/json"}
    if payload is not None:
        data = json.dumps(payload).encode("utf-8")
        headers["Content-Type"] = "application/json"
    request = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(request, timeout=30) as response:
            body = response.read().decode("utf-8")
    except urllib.error.HTTPError as exc:
        body = exc.read().decode("utf-8", errors="replace")
        die(f"Cloudflare API {method} {path} failed ({exc.code}): {cloudflare_error_text(body)}")
    except urllib.error.URLError as exc:
        die(f"Cloudflare API {method} {path} failed: {exc.reason}")
    try:
        decoded = json.loads(body) if body else {}
    except json.JSONDecodeError:
        die(f"Cloudflare API {method} {path} returned invalid JSON")
    if not decoded.get("success", False):
        die(f"Cloudflare API {method} {path} failed: {cloudflare_error_text(body)}")
    return decoded.get("result")


def cloudflare_error_text(body):
    try:
        decoded = json.loads(body) if body else {}
    except json.JSONDecodeError:
        return body.strip() or "unknown error"
    errors = decoded.get("errors")
    if isinstance(errors, list) and errors:
        messages = []
        for error in errors:
            messages.append(str(error.get("message") if isinstance(error, dict) else error))
        return "; ".join(messages)
    return body.strip() or "unknown error"


def cloudflare_account_id(token, preferred=None):
    if preferred:
        return preferred
    result = cloudflare_api_request(token, "GET", "/accounts", query={"per_page": 50})
    if not isinstance(result, list):
        die("Cloudflare API returned invalid accounts response")
    if len(result) != 1:
        die("Cloudflare account id is required when the API token can access multiple accounts")
    account_id = result[0].get("id") if isinstance(result[0], dict) else None
    if not account_id:
        die("Cloudflare API returned an account without an id")
    return account_id


def ensure_cloudflare_tunnel(token, account_id, name):
    existing = cloudflare_api_request(token, "GET", f"/accounts/{account_id}/cfd_tunnel", query={"per_page": 100})
    if isinstance(existing, list):
        for tunnel in existing:
            if isinstance(tunnel, dict) and tunnel.get("name") == name and not tunnel.get("deleted_at"):
                tunnel_id = tunnel.get("id")
                if tunnel_id:
                    return tunnel_id
    created = cloudflare_api_request(
        token,
        "POST",
        f"/accounts/{account_id}/cfd_tunnel",
        payload={"name": name, "config_src": "cloudflare"},
    )
    tunnel_id = created.get("id") if isinstance(created, dict) else None
    if not tunnel_id:
        die("Cloudflare API did not return a tunnel id")
    return tunnel_id


def cloudflare_tunnel_config(token, account_id, tunnel_id):
    result = cloudflare_api_request(token, "GET", f"/accounts/{account_id}/cfd_tunnel/{tunnel_id}/configurations")
    if isinstance(result, dict):
        config = result.get("config")
        if isinstance(config, dict) and isinstance(config.get("ingress"), list):
            return config
    return {"ingress": [{"service": "http_status:404"}]}


def put_cloudflare_tunnel_config(token, account_id, tunnel_id, config):
    cloudflare_api_request(
        token,
        "PUT",
        f"/accounts/{account_id}/cfd_tunnel/{tunnel_id}/configurations",
        payload={"config": config},
    )


def with_cloudflare_hostname(config, host, service):
    ingress = [item for item in config.get("ingress", []) if isinstance(item, dict)]
    catch_all = [item for item in ingress if "hostname" not in item]
    managed = [item for item in ingress if item.get("hostname") != host and "hostname" in item]
    managed.append({"hostname": host, "service": service})
    return {**config, "ingress": managed + (catch_all or [{"service": "http_status:404"}])}


def without_cloudflare_hostname(config, host):
    ingress = [item for item in config.get("ingress", []) if isinstance(item, dict)]
    next_ingress = [item for item in ingress if item.get("hostname") != host]
    if not any("hostname" not in item for item in next_ingress):
        next_ingress.append({"service": "http_status:404"})
    return {**config, "ingress": next_ingress}


def cloudflare_zone_for_host(token, host):
    parts = host.split(".")
    for index in range(0, max(len(parts) - 1, 0)):
        candidate = ".".join(parts[index:])
        result = cloudflare_api_request(token, "GET", "/zones", query={"name": candidate, "per_page": 1})
        if isinstance(result, list) and result:
            zone = result[0]
            if isinstance(zone, dict) and zone.get("id"):
                return zone["id"]
    die(f"Cloudflare zone not found for {host}")


def ensure_cloudflare_cname(token, zone_id, host, target):
    result = cloudflare_api_request(
        token,
        "GET",
        f"/zones/{zone_id}/dns_records",
        query={"type": "CNAME", "name": host, "per_page": 100},
    )
    records = result if isinstance(result, list) else []
    payload = {"type": "CNAME", "name": host, "content": target, "ttl": 1, "proxied": True}
    if len(records) > 1:
        die(f"multiple Cloudflare CNAME records found for {host}")
    if records:
        record_id = records[0].get("id") if isinstance(records[0], dict) else None
        if not record_id:
            die(f"Cloudflare CNAME record for {host} has no id")
        cloudflare_api_request(token, "PATCH", f"/zones/{zone_id}/dns_records/{record_id}", payload=payload)
        return record_id
    created = cloudflare_api_request(token, "POST", f"/zones/{zone_id}/dns_records", payload=payload)
    record_id = created.get("id") if isinstance(created, dict) else None
    if not record_id:
        die(f"Cloudflare API did not return a DNS record id for {host}")
    return record_id


def delete_cloudflare_dns_record(token, zone_id, record_id):
    cloudflare_api_request(token, "DELETE", f"/zones/{zone_id}/dns_records/{record_id}")


def normalize_host(value):
    host = value.strip().lower().rstrip(".")
    if not host:
        die("host cannot be empty")
    if not HOST_RE.match(host):
        die(f"invalid host: {value}")
    return host


def normalize_port(value):
    try:
        port = int(value)
    except (TypeError, ValueError):
        die(f"invalid port: {value}")
    if port < 1 or port > 65535:
        die(f"invalid port: {port}")
    return port


def normalize_app(value):
    if value is None or value == "":
        return None
    app = str(value).strip()
    if not APP_RE.match(app):
        die(f"invalid app name: {value}")
    return app


def normalize_service(value):
    service = str(value).strip()
    if not SERVICE_RE.match(service):
        die(f"invalid service name: {value}")
    if service in {"current", "releases", "shared"}:
        die(f"reserved service name: {service}")
    return service


def path_is_relative_to(path, base):
    try:
        path.relative_to(base)
        return True
    except ValueError:
        return False


def app_path(name):
    return APP_ROOT / name


def app_user(name):
    return f"app-{name}"


def service_unit_name(name, service):
    return f"simple-{name}-{service}.service"


def normalize_root(value, app=None):
    root = str(value).strip()
    if not root:
        die("root cannot be empty")
    if "\n" in root or "\r" in root:
        die("root cannot contain newlines")
    if not root.startswith("/"):
        die("static route root must be an absolute path")
    normalized = root.rstrip("/") or "/"
    if app:
        resolved = Path(normalized).resolve(strict=False)
        base = app_path(app).resolve(strict=False)
        if not path_is_relative_to(resolved, base):
            die(f"static route root for app {app} must be under {base}")
    return normalized


def normalize_redirect_target(value):
    target = str(value).strip()
    if not target:
        die("redirect target cannot be empty")
    if "\n" in target or "\r" in target or any(ch.isspace() for ch in target):
        die("redirect target cannot contain whitespace")
    if not (target.startswith("https://") or target.startswith("http://")):
        die("redirect target must start with http:// or https://")
    return target


def normalize_headers(value):
    if value in (None, ""):
        return {}
    if not isinstance(value, dict):
        die("headers must be an object")

    headers = {}
    for raw_name, raw_value in value.items():
        name = str(raw_name).strip()
        header_value = str(raw_value).strip()
        if not HEADER_NAME_RE.match(name):
            die(f"invalid header name: {raw_name}")
        if "\n" in header_value or "\r" in header_value:
            die(f"invalid header value for {name}: newlines are not allowed")
        headers[name] = header_value
    return dict(sorted(headers.items(), key=lambda item: item[0].lower()))


def parse_header_args(values):
    headers = {}
    for value in values or []:
        if ":" not in value:
            die(f"invalid header {value!r}; expected 'Name: value'")
        name, header_value = value.split(":", 1)
        parsed = normalize_headers({name: header_value})
        headers.update(parsed)
    return headers


def normalize_route(route):
    host = normalize_host(str(route.get("host", "")))
    route_type = str(route.get("type") or ("proxy" if "port" in route else "")).strip().lower()
    app = normalize_app(route.get("app"))
    headers = normalize_headers(route.get("headers", {}))

    normalized = {"host": host, "type": route_type}
    if app:
        normalized["app"] = app
    if headers:
        normalized["headers"] = headers

    if route_type == "proxy":
        normalized["port"] = normalize_port(route.get("port"))
    elif route_type == "static":
        normalized["root"] = normalize_root(route.get("root"), app=app)
    elif route_type == "redirect":
        normalized.pop("headers", None)
        normalized["to"] = normalize_redirect_target(route.get("to"))
    else:
        die(f"invalid route type for {host}: {route_type}")

    return normalized


def sort_routes(routes):
    return sorted(routes, key=lambda route: route["host"])


def route_index(routes, host):
    for index, route in enumerate(routes):
        if route["host"] == host:
            return index
    return None


def caddy_quote(value):
    text = str(value)
    if "\n" in text or "\r" in text:
        die("Caddyfile values cannot contain newlines")
    return json.dumps(text)


def managed_content(body):
    if not body.endswith("\n"):
        body += "\n"
    digest = hashlib.sha256(body.encode("utf-8")).hexdigest()
    return f"{GENERATED_MARKER}\n{HASH_PREFIX}{digest}\n{body}"


def managed_hash_is_valid(content):
    lines = content.splitlines(keepends=True)
    if len(lines) < 2 or lines[0].rstrip("\n") != GENERATED_MARKER:
        return False
    hash_line = lines[1].strip()
    if not hash_line.startswith(HASH_PREFIX):
        return False
    expected = hash_line[len(HASH_PREFIX) :]
    body = "".join(lines[2:])
    actual = hashlib.sha256(body.encode("utf-8")).hexdigest()
    return actual == expected


def is_old_simple_vps_generated(content):
    lines = content.splitlines()
    return len(lines) >= 2 and lines[0] == GENERATED_MARKER and lines[1].startswith("# Source:")


def is_default_caddyfile(content):
    return "root * /usr/share/caddy" in content and "file_server" in content


def ensure_can_replace_managed_file(path, force=False, allow_default=False):
    if force or not path.exists():
        return

    content = path.read_text(encoding="utf-8")
    if managed_hash_is_valid(content) or is_old_simple_vps_generated(content):
        return
    if allow_default and is_default_caddyfile(content):
        return

    die(
        f"manual edits detected in {path}; move custom Caddy config to "
        f"{USER_CADDY_DIR} or rerun with --force"
    )


def render_caddyfile(_state):
    body = "\n".join(
        [
            f"# Source: {STATE_PATH}",
            "",
            "import simple-vps/*.caddy",
            "import conf.d/*.caddy",
            "",
        ]
    )
    return managed_content(body)


def render_headers(headers):
    return [f"\t\theader {name} {caddy_quote(value)}" for name, value in headers.items()]


def render_route(route, index):
    matcher = f"route_{index}"
    lines = [
        f"\t@{matcher} host {route['host']}",
        f"\thandle @{matcher} {{",
    ]
    headers = route.get("headers", {})

    if route["type"] == "proxy":
        lines.extend(render_headers(headers))
        lines.append(f"\t\treverse_proxy 127.0.0.1:{route['port']}")
    elif route["type"] == "static":
        lines.append(f"\t\troot * {caddy_quote(route['root'])}")
        lines.extend(render_headers(headers))
        lines.append("\t\tfile_server")
    elif route["type"] == "redirect":
        lines.append(f"\t\tredir {caddy_quote(route['to'])} permanent")
    else:
        die(f"unsupported route type: {route['type']}")

    lines.extend(["\t}", ""])
    return lines


def render_routes_caddyfile(state):
    lines = [
        f"# Source: {STATE_PATH}",
        "",
        "http://:8080 {",
        "\tbind 127.0.0.1",
    ]

    for index, route in enumerate(sort_routes(state["routes"])):
        lines.extend(render_route(route, index))

    lines.extend(
        [
            '\trespond "Simple VPS Caddy ready" 404',
            "}",
            "",
        ]
    )
    return managed_content("\n".join(lines))


def run_checked(command, cwd=None):
    kwargs = {"text": True, "capture_output": True, "check": False}
    if cwd is not None:
        kwargs["cwd"] = str(cwd)
    result = subprocess.run(command, **kwargs)
    if result.returncode != 0:
        if result.stdout:
            print(result.stdout, file=sys.stderr, end="")
        if result.stderr:
            print(result.stderr, file=sys.stderr, end="")
        die(f"command failed: {' '.join(command)}")


def command_succeeds(command):
    result = subprocess.run(command, text=True, capture_output=True, check=False)
    return result.returncode == 0


def validate_generated_caddy(caddyfile_content, routes_content):
    CADDYFILE_PATH.parent.mkdir(parents=True, exist_ok=True)
    tmp_dir = Path(tempfile.mkdtemp(prefix=".simple-vps-validate.", dir=str(CADDYFILE_PATH.parent)))
    try:
        (tmp_dir / "simple-vps").mkdir()
        (tmp_dir / "conf.d").mkdir()
        (tmp_dir / "Caddyfile").write_text(caddyfile_content, encoding="utf-8")
        (tmp_dir / "simple-vps" / "routes.caddy").write_text(routes_content, encoding="utf-8")
        run_checked([CADDY_BIN, "validate", "--config", str(tmp_dir / "Caddyfile"), "--adapter", "caddyfile"])
    finally:
        shutil.rmtree(tmp_dir, ignore_errors=True)


def restore_files(backup_entries):
    for path, backup_path in reversed(backup_entries):
        if backup_path is None:
            if path.exists():
                path.unlink()
        else:
            shutil.copy2(backup_path, path)


def apply_caddyfile(state, force=False):
    caddyfile_content = render_caddyfile(state)
    routes_content = render_routes_caddyfile(state)
    CADDYFILE_PATH.parent.mkdir(parents=True, exist_ok=True)
    MANAGED_CADDY_DIR.mkdir(parents=True, exist_ok=True)
    USER_CADDY_DIR.mkdir(parents=True, exist_ok=True)

    caddyfile_changed = not (
        CADDYFILE_PATH.exists() and CADDYFILE_PATH.read_text(encoding="utf-8") == caddyfile_content
    )
    routes_changed = not (
        ROUTES_CADDYFILE_PATH.exists()
        and ROUTES_CADDYFILE_PATH.read_text(encoding="utf-8") == routes_content
    )

    if not caddyfile_changed and not routes_changed:
        return False

    validate_generated_caddy(caddyfile_content, routes_content)
    if caddyfile_changed:
        ensure_can_replace_managed_file(CADDYFILE_PATH, force=force, allow_default=True)
    if routes_changed:
        ensure_can_replace_managed_file(ROUTES_CADDYFILE_PATH, force=force)

    backup_entries = []
    try:
        if caddyfile_changed:
            backup_entries.append((CADDYFILE_PATH, backup_file(CADDYFILE_PATH)))
            atomic_write(CADDYFILE_PATH, caddyfile_content, 0o644)
        if routes_changed:
            backup_entries.append((ROUTES_CADDYFILE_PATH, backup_file(ROUTES_CADDYFILE_PATH)))
            atomic_write(ROUTES_CADDYFILE_PATH, routes_content, 0o644)

        try:
            run_checked([CADDY_BIN, "validate", "--config", str(CADDYFILE_PATH), "--adapter", "caddyfile"])
            run_checked([SYSTEMCTL_BIN, "reload", "caddy"])
        except SystemExit:
            restore_files(backup_entries)
            subprocess.run([SYSTEMCTL_BIN, "reload", "caddy"], check=False)
            raise
        return True
    finally:
        pass


class LocalIngress:
    def __init__(self, state=None):
        self.previous_state = state if state is not None else load_state()

    def state_with_routes(self, routes):
        return {"version": STATE_VERSION, "routes": sort_routes(routes)}

    def commit(self, next_state, force=False):
        write_state(next_state)
        try:
            apply_caddyfile(next_state, force=force)
        except SystemExit:
            write_state(self.previous_state)
            raise

    def upsert(self, route, force=False):
        next_routes = [dict(existing) for existing in self.previous_state["routes"]]
        index = route_index(next_routes, route["host"])

        if index is not None:
            existing = next_routes[index]
            if existing == route:
                return f"{route['host']} already has the requested {route['type']} route"
            if not force:
                die(f"{route['host']} already has a {existing['type']} route; use --force to replace it")
            next_routes[index] = route
        else:
            next_routes.append(route)

        self.commit(self.state_with_routes(next_routes), force=force)
        return f"Routed {route['host']} ({route['type']}) -> {route_target(route)}"

    def remove_host(self, host, force=False):
        next_routes = [dict(existing) for existing in self.previous_state["routes"]]
        index = route_index(next_routes, host)
        if index is None:
            die(f"{host} is not routed")

        del next_routes[index]
        self.commit(self.state_with_routes(next_routes), force=force)
        return f"Removed route for {host}"

    def remove_app(self, app, force=False):
        app_name = normalize_app(app)
        next_routes = [route for route in self.previous_state["routes"] if route.get("app") != app_name]
        removed_count = len(self.previous_state["routes"]) - len(next_routes)
        if removed_count == 0:
            return f"No routes found for app {app_name}"

        self.commit(self.state_with_routes(next_routes), force=force)
        plural = "route" if removed_count == 1 else "routes"
        return f"Removed {removed_count} {plural} for app {app_name}"



#!/usr/bin/env python3
import argparse
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from datetime import datetime, timezone
from pathlib import Path


STATE_PATH = Path(os.environ.get("SIMPLE_VPS_STATE_PATH", "/etc/simple-vps/state.json"))
CADDYFILE_PATH = Path(os.environ.get("SIMPLE_VPS_CADDYFILE_PATH", "/etc/caddy/Caddyfile"))
CADDY_ROOT = CADDYFILE_PATH.parent
MANAGED_CADDY_DIR = Path(os.environ.get("SIMPLE_VPS_MANAGED_CADDY_DIR", str(CADDY_ROOT / "simple-vps")))
USER_CADDY_DIR = Path(os.environ.get("SIMPLE_VPS_USER_CADDY_DIR", str(CADDY_ROOT / "conf.d")))
ROUTES_CADDYFILE_PATH = Path(
    os.environ.get("SIMPLE_VPS_ROUTES_CADDYFILE_PATH", str(MANAGED_CADDY_DIR / "routes.caddy"))
)
BACKUP_DIR = Path(os.environ.get("SIMPLE_VPS_BACKUP_DIR", "/etc/simple-vps/backups"))
CADDY_BIN = os.environ.get("SIMPLE_VPS_CADDY_BIN", "caddy")
SYSTEMCTL_BIN = os.environ.get("SIMPLE_VPS_SYSTEMCTL_BIN", "systemctl")
STATE_VERSION = 2
GENERATED_MARKER = "# Generated by Simple VPS. Do not edit by hand."
HASH_PREFIX = "# simple-vps-sha256: "

HOST_RE = re.compile(
    r"^(?=.{1,253}$)(?!-)[a-z0-9-]{1,63}(?<!-)"
    r"(?:\.(?!-)[a-z0-9-]{1,63}(?<!-))*$"
)
APP_RE = re.compile(r"^[a-zA-Z0-9][a-zA-Z0-9_.-]{0,127}$")
HEADER_NAME_RE = re.compile(r"^[A-Za-z0-9!#$%&'*+.^_`|~-]+$")


def die(message, code=1):
    print(f"Error: {message}", file=sys.stderr)
    raise SystemExit(code)


def require_root():
    if hasattr(os, "geteuid") and os.geteuid() != 0:
        die("this command must run as root")


def load_state():
    if not STATE_PATH.exists():
        return {"version": STATE_VERSION, "routes": []}

    try:
        state = json.loads(STATE_PATH.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        die(f"invalid state file {STATE_PATH}: {exc}")

    if not isinstance(state, dict):
        die(f"invalid state file {STATE_PATH}: expected object")

    routes = state.get("routes", [])
    if not isinstance(routes, list):
        die(f"invalid state file {STATE_PATH}: routes must be a list")

    version = int(state.get("version", 1))
    if version > STATE_VERSION:
        die(f"unsupported state version {version}; this simple-vps supports up to {STATE_VERSION}")

    normalized = []
    for route in routes:
        if not isinstance(route, dict):
            die(f"invalid state file {STATE_PATH}: route entries must be objects")
        normalized.append(normalize_route(route))

    return {"version": STATE_VERSION, "routes": sort_routes(normalized)}


def write_state(state):
    STATE_PATH.parent.mkdir(parents=True, exist_ok=True)
    atomic_write(STATE_PATH, json.dumps(state, indent=2, sort_keys=True) + "\n", 0o644)


def atomic_write(path, content, mode):
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp_name = tempfile.mkstemp(prefix=f".{path.name}.", dir=str(path.parent))
    tmp_path = Path(tmp_name)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(content)
            handle.flush()
            os.fsync(handle.fileno())
        os.chmod(tmp_path, mode)
        os.replace(tmp_path, path)
    finally:
        if tmp_path.exists():
            tmp_path.unlink()


def backup_file(path):
    if not path.exists():
        return None

    BACKUP_DIR.mkdir(parents=True, exist_ok=True)
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    backup_path = BACKUP_DIR / f"{path.name}.{stamp}"
    shutil.copy2(path, backup_path)
    return backup_path


def normalize_host(value):
    host = value.strip().lower().rstrip(".")
    if not host:
        die("host cannot be empty")
    if not HOST_RE.match(host):
        die(f"invalid host: {value}")
    return host


def normalize_port(value):
    try:
        port = int(value)
    except (TypeError, ValueError):
        die(f"invalid port: {value}")
    if port < 1 or port > 65535:
        die(f"invalid port: {port}")
    return port


def normalize_app(value):
    if value is None or value == "":
        return None
    app = str(value).strip()
    if not APP_RE.match(app):
        die(f"invalid app name: {value}")
    return app


def normalize_root(value):
    root = str(value).strip()
    if not root:
        die("root cannot be empty")
    if "\n" in root or "\r" in root:
        die("root cannot contain newlines")
    if not root.startswith("/"):
        die("static route root must be an absolute path")
    return root.rstrip("/") or "/"


def normalize_redirect_target(value):
    target = str(value).strip()
    if not target:
        die("redirect target cannot be empty")
    if "\n" in target or "\r" in target or any(ch.isspace() for ch in target):
        die("redirect target cannot contain whitespace")
    if not (target.startswith("https://") or target.startswith("http://")):
        die("redirect target must start with http:// or https://")
    return target


def normalize_headers(value):
    if value in (None, ""):
        return {}
    if not isinstance(value, dict):
        die("headers must be an object")

    headers = {}
    for raw_name, raw_value in value.items():
        name = str(raw_name).strip()
        header_value = str(raw_value).strip()
        if not HEADER_NAME_RE.match(name):
            die(f"invalid header name: {raw_name}")
        if "\n" in header_value or "\r" in header_value:
            die(f"invalid header value for {name}: newlines are not allowed")
        headers[name] = header_value
    return dict(sorted(headers.items(), key=lambda item: item[0].lower()))


def parse_header_args(values):
    headers = {}
    for value in values or []:
        if ":" not in value:
            die(f"invalid header {value!r}; expected 'Name: value'")
        name, header_value = value.split(":", 1)
        parsed = normalize_headers({name: header_value})
        headers.update(parsed)
    return headers


def normalize_route(route):
    host = normalize_host(str(route.get("host", "")))
    route_type = str(route.get("type") or ("proxy" if "port" in route else "")).strip().lower()
    app = normalize_app(route.get("app"))
    headers = normalize_headers(route.get("headers", {}))

    normalized = {"host": host, "type": route_type}
    if app:
        normalized["app"] = app
    if headers:
        normalized["headers"] = headers

    if route_type == "proxy":
        normalized["port"] = normalize_port(route.get("port"))
    elif route_type == "static":
        normalized["root"] = normalize_root(route.get("root"))
    elif route_type == "redirect":
        normalized.pop("headers", None)
        normalized["to"] = normalize_redirect_target(route.get("to"))
    else:
        die(f"invalid route type for {host}: {route_type}")

    return normalized


def sort_routes(routes):
    return sorted(routes, key=lambda route: route["host"])


def route_index(routes, host):
    for index, route in enumerate(routes):
        if route["host"] == host:
            return index
    return None


def caddy_quote(value):
    text = str(value)
    if "\n" in text or "\r" in text:
        die("Caddyfile values cannot contain newlines")
    return json.dumps(text)


def managed_content(body):
    if not body.endswith("\n"):
        body += "\n"
    digest = hashlib.sha256(body.encode("utf-8")).hexdigest()
    return f"{GENERATED_MARKER}\n{HASH_PREFIX}{digest}\n{body}"


def managed_hash_is_valid(content):
    lines = content.splitlines(keepends=True)
    if len(lines) < 2 or lines[0].rstrip("\n") != GENERATED_MARKER:
        return False
    hash_line = lines[1].strip()
    if not hash_line.startswith(HASH_PREFIX):
        return False
    expected = hash_line[len(HASH_PREFIX) :]
    body = "".join(lines[2:])
    actual = hashlib.sha256(body.encode("utf-8")).hexdigest()
    return actual == expected


def is_old_simple_vps_generated(content):
    lines = content.splitlines()
    return len(lines) >= 2 and lines[0] == GENERATED_MARKER and lines[1].startswith("# Source:")


def is_default_caddyfile(content):
    return "root * /usr/share/caddy" in content and "file_server" in content


def ensure_can_replace_managed_file(path, force=False, allow_default=False):
    if force or not path.exists():
        return

    content = path.read_text(encoding="utf-8")
    if managed_hash_is_valid(content) or is_old_simple_vps_generated(content):
        return
    if allow_default and is_default_caddyfile(content):
        return

    die(
        f"manual edits detected in {path}; move custom Caddy config to "
        f"{USER_CADDY_DIR} or rerun with --force"
    )


def render_caddyfile(_state):
    body = "\n".join(
        [
            f"# Source: {STATE_PATH}",
            "",
            "import simple-vps/*.caddy",
            "import conf.d/*.caddy",
            "",
        ]
    )
    return managed_content(body)


def render_headers(headers):
    return [f"\t\theader {name} {caddy_quote(value)}" for name, value in headers.items()]


def render_route(route, index):
    matcher = f"route_{index}"
    lines = [
        f"\t@{matcher} host {route['host']}",
        f"\thandle @{matcher} {{",
    ]
    headers = route.get("headers", {})

    if route["type"] == "proxy":
        lines.extend(render_headers(headers))
        lines.append(f"\t\treverse_proxy 127.0.0.1:{route['port']}")
    elif route["type"] == "static":
        lines.append(f"\t\troot * {caddy_quote(route['root'])}")
        lines.extend(render_headers(headers))
        lines.append("\t\tfile_server")
    elif route["type"] == "redirect":
        lines.append(f"\t\tredir {caddy_quote(route['to'])} permanent")
    else:
        die(f"unsupported route type: {route['type']}")

    lines.extend(["\t}", ""])
    return lines


def render_routes_caddyfile(state):
    lines = [
        f"# Source: {STATE_PATH}",
        "",
        "http://:8080 {",
        "\tbind 127.0.0.1",
    ]

    for index, route in enumerate(sort_routes(state["routes"])):
        lines.extend(render_route(route, index))

    lines.extend(
        [
            '\trespond "Simple VPS Caddy ready" 404',
            "}",
            "",
        ]
    )
    return managed_content("\n".join(lines))


def run_checked(command):
    result = subprocess.run(command, text=True, capture_output=True, check=False)
    if result.returncode != 0:
        if result.stdout:
            print(result.stdout, file=sys.stderr, end="")
        if result.stderr:
            print(result.stderr, file=sys.stderr, end="")
        die(f"command failed: {' '.join(command)}")


def validate_generated_caddy(caddyfile_content, routes_content):
    CADDYFILE_PATH.parent.mkdir(parents=True, exist_ok=True)
    tmp_dir = Path(tempfile.mkdtemp(prefix=".simple-vps-validate.", dir=str(CADDYFILE_PATH.parent)))
    try:
        (tmp_dir / "simple-vps").mkdir()
        (tmp_dir / "conf.d").mkdir()
        (tmp_dir / "Caddyfile").write_text(caddyfile_content, encoding="utf-8")
        (tmp_dir / "simple-vps" / "routes.caddy").write_text(routes_content, encoding="utf-8")
        run_checked([CADDY_BIN, "validate", "--config", str(tmp_dir / "Caddyfile"), "--adapter", "caddyfile"])
    finally:
        shutil.rmtree(tmp_dir, ignore_errors=True)


def restore_files(backup_entries):
    for path, backup_path in reversed(backup_entries):
        if backup_path is None:
            if path.exists():
                path.unlink()
        else:
            shutil.copy2(backup_path, path)


def apply_caddyfile(state, force=False):
    caddyfile_content = render_caddyfile(state)
    routes_content = render_routes_caddyfile(state)
    CADDYFILE_PATH.parent.mkdir(parents=True, exist_ok=True)
    MANAGED_CADDY_DIR.mkdir(parents=True, exist_ok=True)
    USER_CADDY_DIR.mkdir(parents=True, exist_ok=True)

    caddyfile_changed = not (
        CADDYFILE_PATH.exists() and CADDYFILE_PATH.read_text(encoding="utf-8") == caddyfile_content
    )
    routes_changed = not (
        ROUTES_CADDYFILE_PATH.exists()
        and ROUTES_CADDYFILE_PATH.read_text(encoding="utf-8") == routes_content
    )

    if not caddyfile_changed and not routes_changed:
        return False

    validate_generated_caddy(caddyfile_content, routes_content)
    if caddyfile_changed:
        ensure_can_replace_managed_file(CADDYFILE_PATH, force=force, allow_default=True)
    if routes_changed:
        ensure_can_replace_managed_file(ROUTES_CADDYFILE_PATH, force=force)

    backup_entries = []
    try:
        if caddyfile_changed:
            backup_entries.append((CADDYFILE_PATH, backup_file(CADDYFILE_PATH)))
            atomic_write(CADDYFILE_PATH, caddyfile_content, 0o644)
        if routes_changed:
            backup_entries.append((ROUTES_CADDYFILE_PATH, backup_file(ROUTES_CADDYFILE_PATH)))
            atomic_write(ROUTES_CADDYFILE_PATH, routes_content, 0o644)

        try:
            run_checked([CADDY_BIN, "validate", "--config", str(CADDYFILE_PATH), "--adapter", "caddyfile"])
            run_checked([SYSTEMCTL_BIN, "reload", "caddy"])
        except SystemExit:
            restore_files(backup_entries)
            subprocess.run([SYSTEMCTL_BIN, "reload", "caddy"], check=False)
            raise
        return True
    finally:
        pass


def commit_state_and_caddyfile(previous_state, next_state, force=False):
    write_state(next_state)
    try:
        apply_caddyfile(next_state, force=force)
    except SystemExit:
        write_state(previous_state)
        raise


def cmd_status(_args):
    state = load_state()
    print("Simple VPS")
    print(f"state: {STATE_PATH}")
    print(f"routes: {len(state['routes'])}")
    print("services:")
    for service in ("tailscaled", "cloudflared", "caddy"):
        status = service_status(service)
        print(f"  {service}: {status}")
    print("tools:")
    for tool in ("litestream", "node", "bun", "pnpm", "pm2"):
        print(f"  {tool}: {tool_status(tool)}")


def service_status(service):
    result = subprocess.run(
        [SYSTEMCTL_BIN, "is-active", service],
        text=True,
        capture_output=True,
        check=False,
    )
    value = (result.stdout or result.stderr).strip()
    return value if value else f"exit {result.returncode}"


def tool_status(tool):
    path = shutil.which(tool)
    if path is None:
        return "missing"

    command = [tool, "--version"]
    if tool == "pm2":
        command = [tool, "-v"]

    result = subprocess.run(
        command,
        text=True,
        capture_output=True,
        check=False,
    )
    value = (result.stdout or result.stderr).strip().splitlines()
    if result.returncode == 0 and value:
        return f"installed ({value[0]})"
    if result.returncode == 0:
        return "installed"
    return f"installed (version check failed: exit {result.returncode})"


def cmd_routes(_args):
    routes = load_state()["routes"]
    if getattr(_args, "json", False):
        print(json.dumps({"routes": routes}, indent=2, sort_keys=True))
        return
    if not routes:
        print("No routes configured.")
        return

    host_width = max(len("HOST"), *(len(route["host"]) for route in routes))
    type_width = max(len("TYPE"), *(len(route["type"]) for route in routes))
    target_width = max(len("TARGET"), *(len(route_target(route)) for route in routes))
    print(f"{'HOST'.ljust(host_width)}  {'TYPE'.ljust(type_width)}  {'TARGET'.ljust(target_width)}  APP")
    for route in routes:
        print(
            f"{route['host'].ljust(host_width)}  "
            f"{route['type'].ljust(type_width)}  "
            f"{route_target(route).ljust(target_width)}  "
            f"{route.get('app', '')}"
        )


def route_target(route):
    if route["type"] == "proxy":
        return f"127.0.0.1:{route['port']}"
    if route["type"] == "static":
        return route["root"]
    if route["type"] == "redirect":
        return route["to"]
    return ""


def upsert_route(route, force=False):
    previous_state = load_state()
    next_state = {
        "version": STATE_VERSION,
        "routes": [dict(existing) for existing in previous_state["routes"]],
    }
    routes = next_state["routes"]
    index = route_index(routes, route["host"])

    if index is not None:
        existing = routes[index]
        if existing == route:
            print(f"{route['host']} already has the requested {route['type']} route")
            return
        if not force:
            die(f"{route['host']} already has a {existing['type']} route; use --force to replace it")
        routes[index] = route
    else:
        routes.append(route)

    next_state["routes"] = sort_routes(routes)
    commit_state_and_caddyfile(previous_state, next_state, force=force)
    print(f"Routed {route['host']} ({route['type']}) -> {route_target(route)}")


def remove_route(host, force=False):
    previous_state = load_state()
    next_state = {
        "version": STATE_VERSION,
        "routes": [dict(existing) for existing in previous_state["routes"]],
    }
    routes = next_state["routes"]
    index = route_index(routes, host)
    if index is None:
        die(f"{host} is not routed")

    del routes[index]
    next_state["routes"] = sort_routes(routes)
    commit_state_and_caddyfile(previous_state, next_state, force=force)
    print(f"Removed route for {host}")


def cmd_route_proxy(args):
    require_root()
    route = normalize_route(
        {
            "host": args.host,
            "type": "proxy",
            "port": args.port,
            "app": args.app,
            "headers": parse_header_args(args.header),
        }
    )
    upsert_route(route, force=args.force)


def cmd_route_static(args):
    require_root()
    route = normalize_route(
        {
            "host": args.host,
            "type": "static",
            "root": args.root,
            "app": args.app,
            "headers": parse_header_args(args.header),
        }
    )
    upsert_route(route, force=args.force)


def cmd_route_redirect(args):
    require_root()
    route = normalize_route(
        {
            "host": args.host,
            "type": "redirect",
            "to": args.to,
            "app": args.app,
        }
    )
    upsert_route(route, force=args.force)


def cmd_route_remove(args):
    require_root()
    host = normalize_host(args.host)
    remove_route(host, force=args.force)


def cmd_publish(args):
    require_root()
    route = normalize_route({"host": args.host, "type": "proxy", "port": args.port})
    upsert_route(route, force=args.force)


def cmd_unpublish(args):
    require_root()
    host = normalize_host(args.host)
    remove_route(host, force=getattr(args, "force", False))


def cmd_generate_caddy(_args):
    require_root()
    state = load_state()
    changed = apply_caddyfile(state, force=getattr(_args, "force", False))
    if changed:
        print(f"Generated {CADDYFILE_PATH}")
    else:
        print(f"{CADDYFILE_PATH} already up to date")


def build_parser():
    parser = argparse.ArgumentParser(prog="simple-vps")
    subparsers = parser.add_subparsers(dest="command", required=True)

    status = subparsers.add_parser("status", help="Show server status")
    status.set_defaults(func=cmd_status)

    routes = subparsers.add_parser("routes", help="List routes")
    routes.add_argument("--json", action="store_true")
    routes.set_defaults(func=cmd_routes)

    route = subparsers.add_parser("route", help="Manage routes")
    route_subparsers = route.add_subparsers(dest="route_command", required=True)

    route_list = route_subparsers.add_parser("list", help="List routes")
    route_list.add_argument("--json", action="store_true")
    route_list.set_defaults(func=cmd_routes)

    route_proxy = route_subparsers.add_parser("proxy", help="Route a host to a local app port")
    route_proxy.add_argument("host")
    route_proxy.add_argument("--port", required=True)
    route_proxy.add_argument("--app")
    route_proxy.add_argument("--header", action="append", default=[])
    route_proxy.add_argument("--force", action="store_true")
    route_proxy.set_defaults(func=cmd_route_proxy)

    route_static = route_subparsers.add_parser("static", help="Route a host to a static directory")
    route_static.add_argument("host")
    route_static.add_argument("--root", required=True)
    route_static.add_argument("--app")
    route_static.add_argument("--header", action="append", default=[])
    route_static.add_argument("--force", action="store_true")
    route_static.set_defaults(func=cmd_route_static)

    route_redirect = route_subparsers.add_parser("redirect", help="Redirect a host to another URL")
    route_redirect.add_argument("host")
    route_redirect.add_argument("--to", required=True)
    route_redirect.add_argument("--app")
    route_redirect.add_argument("--force", action="store_true")
    route_redirect.set_defaults(func=cmd_route_redirect)

    route_remove = route_subparsers.add_parser("remove", help="Remove a route by host")
    route_remove.add_argument("host")
    route_remove.add_argument("--force", action="store_true")
    route_remove.set_defaults(func=cmd_route_remove)

    publish = subparsers.add_parser("publish", help="Publish a host to a local app port")
    publish.add_argument("--host", required=True)
    publish.add_argument("--port", required=True)
    publish.add_argument("--force", action="store_true")
    publish.set_defaults(func=cmd_publish)

    unpublish = subparsers.add_parser("unpublish", help="Remove a published host")
    unpublish.add_argument("--host", required=True)
    unpublish.add_argument("--force", action="store_true")
    unpublish.set_defaults(func=cmd_unpublish)

    generate = subparsers.add_parser(
        "generate-caddy",
        help="Regenerate /etc/caddy/Caddyfile from state",
    )
    generate.add_argument("--force", action="store_true")
    generate.set_defaults(func=cmd_generate_caddy)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()

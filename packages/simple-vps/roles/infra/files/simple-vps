class CloudflareIngress:
    def __init__(self, token, state, account_id, tunnel_id):
        self.token = token
        self.state = state
        self.account_id = account_id
        self.tunnel_id = tunnel_id

    @classmethod
    def configured(cls):
        configured = configured_cloudflare()
        if configured is None:
            return None
        token, state, account_id, tunnel_id = configured
        return cls(token, state, account_id, tunnel_id)

    def replace_tunnel_config(self, previous_config, next_config, after_replace):
        put_cloudflare_tunnel_config(self.token, self.account_id, self.tunnel_id, next_config)
        try:
            return after_replace()
        except SystemExit:
            put_cloudflare_tunnel_config(self.token, self.account_id, self.tunnel_id, previous_config)
            raise

    def publish(self, host, app):
        previous_config = cloudflare_tunnel_config(self.token, self.account_id, self.tunnel_id)
        next_config = with_cloudflare_hostname(previous_config, host, cloudflare_route_service())

        def write_dns_record():
            # Explicit failures roll back the tunnel config. A process kill here can
            # still leave orphaned ingress; a future doctor/repair path should catch it.
            zone_id = cloudflare_zone_for_host(self.token, host)
            record_id = ensure_cloudflare_cname(
                self.token,
                zone_id,
                host,
                f"{self.tunnel_id}.cfargotunnel.com",
            )
            return zone_id, record_id

        zone_id, record_id = self.replace_tunnel_config(previous_config, next_config, write_dns_record)
        routes = self.state.setdefault("routes", {})
        routes[host] = {"app": app, "zone_id": zone_id, "dns_record_id": record_id}
        write_cloudflare_state(self.state)
        return f"Cloudflare route ready: {host}"

    def remove_host(self, host, route_state):
        previous_config = cloudflare_tunnel_config(self.token, self.account_id, self.tunnel_id)
        next_config = without_cloudflare_hostname(previous_config, host)

        def delete_dns_record():
            zone_id = route_state.get("zone_id") if isinstance(route_state, dict) else None
            record_id = route_state.get("dns_record_id") if isinstance(route_state, dict) else None
            if zone_id and record_id:
                delete_cloudflare_dns_record(self.token, zone_id, record_id)

        self.replace_tunnel_config(previous_config, next_config, delete_dns_record)

    def remove(self, host=None, app=None):
        routes = self.state.setdefault("routes", {})
        if host:
            targets = [(host, routes.get(host))]
        else:
            app_name = normalize_app(app)
            targets = [
                (route_host, route)
                for route_host, route in routes.items()
                if isinstance(route, dict) and route.get("app") == app_name
            ]

        if not targets:
            return []

        removed = []
        for route_host, route_state in targets:
            self.remove_host(route_host, route_state)
            routes.pop(route_host, None)
            removed.append(route_host)
        write_cloudflare_state(self.state)
        return removed



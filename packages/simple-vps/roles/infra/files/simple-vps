    app_run_as.add_argument("run_command", nargs=argparse.REMAINDER)
    app_run_as.set_defaults(func=cmd_app_run_as)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()

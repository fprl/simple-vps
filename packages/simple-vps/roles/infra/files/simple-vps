    app_install_unit.add_argument("name")
    app_install_unit.add_argument("service")
    app_install_unit.add_argument("path_to_unit_file")
    app_install_unit.set_defaults(func=cmd_app_install_unit)

    app_uninstall_unit = app_subparsers.add_parser("uninstall-unit", help="Remove an app systemd unit")

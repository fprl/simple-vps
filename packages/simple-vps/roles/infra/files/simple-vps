def validate_unit_source(path, name, service):
    resolved = Path(path).resolve(strict=False)
    tmp_root = DEPLOY_TMP_DIR.resolve(strict=False)
    if not path_is_relative_to(resolved, tmp_root):
        die(f"unit file must live under {tmp_root}")
    if not resolved.is_file():
        die(f"unit file does not exist: {path}")

    sudo_uid = os.environ.get("SUDO_UID")
    if sudo_uid is not None:
        try:
            expected_uid = int(sudo_uid)
        except ValueError:
            die("invalid SUDO_UID")
        actual_uid = resolved.stat().st_uid
        if actual_uid != expected_uid:
            die(f"unit file must be owned by invoking sudo user (uid {expected_uid})")

    content = resolved.read_text(encoding="utf-8")
    if not content.startswith("[Unit]"):
        die("unit file must start with [Unit]")

    lines = [line.strip() for line in content.splitlines()]
    expected_user = f"User={app_user(name)}"
    if expected_user not in lines:
        die(f"unit file must contain {expected_user}")

    for line in lines:
        if line.startswith("User=") and line != expected_user:
            die("unit file contains unexpected User= directive")
        if line.startswith("Group=") and line != f"Group={app_user(name)}":
            die("unit file contains unexpected Group= directive")

    unit_name = service_unit_name(name, service)
    if resolved.name != unit_name:
        die(f"unit file name must be {unit_name}")
    return resolved


def validate_deploy_tmp_source(path):
    resolved = Path(path).resolve(strict=False)
    tmp_root = DEPLOY_TMP_DIR.resolve(strict=False)
    if not path_is_relative_to(resolved, tmp_root):
        die(f"source file must live under {tmp_root}")
    if not resolved.is_file():
        die(f"source file does not exist: {path}")

    sudo_uid = os.environ.get("SUDO_UID")
    if sudo_uid is not None:
        try:
            expected_uid = int(sudo_uid)
        except ValueError:
            die("invalid SUDO_UID")
        actual_uid = resolved.stat().st_uid
        if actual_uid != expected_uid:
            die(f"source file must be owned by invoking sudo user (uid {expected_uid})")
    return resolved


def validate_environment_content(content):
    if "\x00" in content:
        die("env file cannot contain NUL bytes")
    for index, raw_line in enumerate(content.split("\n"), start=1):
        line = raw_line.rstrip("\r")
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if stripped.startswith("export "):
            die(f"line {index}: export is not supported")
        if "=" not in line:
            die(f"line {index}: expected KEY=value")
        key, value = line.split("=", 1)
        if key.strip() != key:
            die(f"line {index}: whitespace around keys is not supported")
        if not ENV_KEY_RE.match(key):
            die(f"line {index}: invalid env key: {key}")
        if value.startswith('"') or value.startswith("'"):
            die(f"line {index}: quoted values are not supported")
        if re.search(r"\s+#", value):
            die(f"line {index}: inline comments are not supported")



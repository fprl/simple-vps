def sudoers_paths():
    if not SUDOERS_DIR.exists():
        return []
    return [path for path in sorted(SUDOERS_DIR.iterdir()) if path.is_file()]


def sudoers_lines(path):
    try:
        raw_lines = path.read_text(encoding="utf-8").splitlines()
    except OSError:
        return []
    return [line.strip() for line in raw_lines if line.strip() and not line.strip().startswith("#")]


def sudoers_users_matching(path, pattern):
    users = set()
    for line in sudoers_lines(path):
        match = pattern.match(line)
        if match:
            users.add(match.group(1))
    return users


def all_sudoers_users_matching(pattern):
    users = set()
    for path in sudoers_paths():
        users.update(sudoers_users_matching(path, pattern))
    return users


def doctor_identity_findings():
    operator_file = SUDOERS_DIR / "operator"
    helper_file = SUDOERS_DIR / "simple-vps"
    broad_users = all_sudoers_users_matching(BROAD_SUDO_RE)
    helper_users = all_sudoers_users_matching(HELPER_SUDO_RE)
    operator_users = sudoers_users_matching(operator_file, BROAD_SUDO_RE)
    deploy_users = sudoers_users_matching(helper_file, HELPER_SUDO_RE)
    findings = []

    if not operator_users:
        findings.append(f"missing broad operator sudoers grant in {operator_file}")
    if len(operator_users) > 1:
        findings.append(f"multiple operator sudoers users in {operator_file}: {', '.join(sorted(operator_users))}")

    if not deploy_users:
        findings.append(f"missing deploy helper sudoers grant in {helper_file}")
    if len(deploy_users) > 1:
        findings.append(f"multiple deploy sudoers users in {helper_file}: {', '.join(sorted(deploy_users))}")

    if operator_users and deploy_users:
        operator_user = next(iter(operator_users))
        deploy_user = next(iter(deploy_users))
        if operator_user == deploy_user:
            findings.append(f"operator and deploy are both {operator_user}")
        if deploy_user in broad_users:
            findings.append(f"deploy user {deploy_user} has broad passwordless sudo")

    if "admin" in broad_users and "admin" in helper_users:
        findings.append("legacy admin conflation is present")
    elif "admin" in broad_users and "admin" not in operator_users:
        findings.append("legacy broad admin sudoers grant is present")

    return findings


def cmd_doctor(_args):
    findings = doctor_identity_findings()
    print("Simple VPS doctor")
    if findings:
        print("identity: degraded")
        for finding in findings:
            print(f"  - {finding}")
        raise SystemExit(1)
    print("identity: healthy")



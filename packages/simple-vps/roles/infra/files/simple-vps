    run_checked(command)


def normalize_cwd(name, value):
    root = app_path(name).resolve(strict=False)
    cwd = Path(value or root).resolve(strict=False)
    if not path_is_relative_to(cwd, root):
        die(f"cwd must be under {root}")
    if not cwd.is_dir():
        die(f"cwd does not exist: {cwd}")
    return cwd


def validate_run_command(command):
    if not command:
        die("missing command after --")
    if command[0] == "--":
        command = command[1:]
    if not command:
        die("missing command after --")
    for arg in command:
        if "\x00" in arg or "\n" in arg or "\r" in arg:
            die("command arguments cannot contain NULs or newlines")
    return command


def cmd_app_run_as(args):
    require_root()
    name = normalize_app(args.name)
    run_command = list(args.run_command)
    cwd_value = args.cwd
    if cwd_value is None and len(run_command) >= 2 and run_command[0] == "--cwd":
        cwd_value = run_command[1]
        run_command = run_command[2:]
    if cwd_value is None:
        die("missing --cwd")
    cwd = normalize_cwd(name, cwd_value)
    command = validate_run_command(run_command)
    run_checked(["runuser", "-u", app_user(name), "--", *command], cwd=cwd)



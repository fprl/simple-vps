# VPS-safe default .zshrc (derived from your Mac config, sanitized).
# - No secrets
# - No Mac-specific paths (/opt/homebrew, $HOME/Library)
# - No VS Code / GUI integrations
# - No host-specific aliases

# Powerlevel10k instant prompt (optional; harmless on VPS)
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

plugins=(
  git
  zsh-autosuggestions
  zsh-syntax-highlighting
  fzf
  zoxide
)

if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
fi

if command -v fzf >/dev/null 2>&1; then
  source <(fzf --zsh)
fi

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init zsh)"
fi

export EDITOR="vim"
export VISUAL="vim"

export PATH="$HOME/.local/bin:$PATH"

alias ls="lsd"
alias ll="lsd -la"
alias la="lsd -a"
alias lt="lsd --tree"
alias cat="bat 2>/dev/null || cat"

[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

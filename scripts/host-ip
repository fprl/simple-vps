#!/usr/bin/env bash
set -euo pipefail

# Resolve a target IP from either:
# - IP=1.2.3.4 (direct)
# - HOST=name (lookup ansible_host from inventory)

IP_ARG="${IP:-}"
HOST_ARG="${HOST:-}"

if [[ -n "$IP_ARG" ]]; then
  printf '%s\n' "$IP_ARG"
  exit 0
fi

if [[ -z "$HOST_ARG" ]]; then
  echo "Error: set HOST=<inventory-name> or IP=<address>" >&2
  exit 2
fi

if ! command -v ansible-inventory >/dev/null 2>&1; then
  echo "Error: ansible-inventory not found (install ansible)" >&2
  exit 2
fi

# ansible-inventory outputs JSON; use python to parse ansible_host.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INV_FILE="$SCRIPT_DIR/../inventory/hosts.ini"
export INV_FILE

if [[ ! -f "$INV_FILE" ]]; then
  echo "Error: inventory not found: $INV_FILE" >&2
  exit 2
fi

python3 - <<'PY'
import json
import os
import subprocess
import sys

host = os.environ.get('HOST')
if not host:
    print('Error: HOST env var not set', file=sys.stderr)
    sys.exit(2)

inv = os.environ.get('INV_FILE')
if not inv:
    print('Error: INV_FILE env var not set', file=sys.stderr)
    sys.exit(2)

try:
    out = subprocess.check_output(['ansible-inventory', '-i', inv, '--host', host], text=True)
except subprocess.CalledProcessError as e:
    print(e.output or str(e), file=sys.stderr)
    sys.exit(2)

data = json.loads(out)
ip = data.get('ansible_host') or data.get('inventory_hostname')
if not ip:
    print(f'Error: could not resolve ansible_host for {host}', file=sys.stderr)
    sys.exit(2)

print(ip)
PY
